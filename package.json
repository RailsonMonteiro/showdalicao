{
  "name": "show-da-licao-modo-equipes",
  "private": true,
  "version": "1.0.2",
  "description": "Aplicativo em React para o jogo Show da Lição - modo equipes.",
  "author": "Railson Monteiro",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "dev:desktop": "concurrently -k \"vite\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "gen:icon:win": "node scripts/generate-win-icon.cjs",
    "dist:win": "npm run gen:icon:win && npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.showdalicao.app",
    "productName": "Show da Licao",
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "RailsonMonteiro",
        "repo": "showdalicao"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "img/ico.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Show da Lição",
      "installerIcon": "img/ico.ico",
      "uninstallerIcon": "img/ico.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "rcedit": "^4.0.1",
    "sharp": "^0.34.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
